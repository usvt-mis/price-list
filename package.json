{
  "name": "pricelist-calculator",
  "version": "1.0.4",
  "description": "Price List Calculator - Web application for calculating service costs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "predeploy": "echo \"Deploying to Azure App Service...\"",
    "db:clear-salesquote-operational-data": "node api/scripts/clear-salesquote-operational-data.js",
    "build:css": "tailwindcss -i ./src/css/input.css -o ./src/css/output.css --minify",
    "watch:css": "tailwindcss -i ./src/css/input.css -o ./src/css/output.css --watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@azure/functions": "^4.0.0",
    "applicationinsights": "^2.5.0",
    "axios": "^1.7.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "html2pdf.js": "^0.14.0",
    "jsonwebtoken": "^9.0.3",
    "mssql": "^10.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "autoprefixer": "^10.4.27",
    "nodemon": "^3.0.1",
    "tailwindcss": "^3.4.19"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
